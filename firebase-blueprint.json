{
  "entities": {
    "Submission": {
      "title": "Submission",
      "description": "A content submission from an affiliate.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The affiliate's full name."
        },
        "accountName": {
          "type": "string",
          "description": "The affiliate's account name."
        },
        "contentLink": {
          "type": "string",
          "format": "uri",
          "description": "The link to the posted content."
        },
        "boostCode": {
          "type": "string",
          "description": "The boost code used."
        },
        "postDate": {
          "type": "string",
          "format": "date",
          "description": "The date the content was posted."
        },
        "submissionTimestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the data was submitted."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "The status of the submission."
        },
        "isSynced": {
          "type": "boolean",
          "description": "Whether the record has been synced to Google Sheets."
        }
      },
      "required": ["fullName", "accountName", "contentLink", "status"]
    },
    "Registration": {
      "title": "Registration",
      "description": "An affiliate registration application.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "The applicant's full name."
        },
        "accountTikTok": {
          "type": "string",
          "description": "TikTok account name."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "Active WA number."
        },
        "registrationTimestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When they registered."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "qualified", "rejected"],
          "description": "The status of the registration."
        },
        "isSynced": {
          "type": "boolean",
          "description": "Whether the record has been synced to Google Sheets."
        }
      },
      "required": ["fullName", "accountTikTok", "whatsappNumber", "status"]
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Collection of affiliate submissions."
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of affiliate registrations."
    }
  }
}
